PERSISTENCE=file

# --- Supabase ---
# Public values used by the browser/server clients (cookie-based auth).
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service-role key. Server-only; never expose to the browser. Used by the
# admin client (migration script) and any operations that must bypass RLS.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: explicit site origin used for OAuth redirect URLs. If unset,
# the auth actions derive it from the request headers.
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- AWS S3 (PDF uploads in supabase mode) ---
AWS_REGION=us-east-1
AWS_S3_BUCKET=studygit-uploads
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
