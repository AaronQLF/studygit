PERSISTENCE=file

# --- Supabase ---
# Public values used by the browser/server clients (cookie-based auth).
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service-role key. Server-only; never expose to the browser. Used by the
# admin client (migration script) and any operations that must bypass RLS.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: explicit site origin used for OAuth redirect URLs. If unset,
# the auth actions derive it from the request headers.
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Cloudflare R2 (object storage for PDF uploads in supabase mode) ---
# R2 is S3-API-compatible. Mint API tokens at
# https://dash.cloudflare.com → R2 → Manage API Tokens, then create a bucket.
R2_ACCOUNT_ID=your-r2-account-id
R2_BUCKET=studygit-uploads
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
# Optional override; defaults to https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com
# R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com

# --- Compression / chunking knobs (all optional) ---
# zstd compression level applied per chunk. 1–9 is "fast", 19–22 is "ultra".
# Default 19 trades a chunk's worth of CPU for ~5–15% smaller storage vs. 3.
# ZSTD_LEVEL=19
# FastCDC content-defined chunking targets, in bytes. Defaults: 64K / 256K / 1M.
# Smaller chunks = better dedup but more manifests/list overhead. Larger
# chunks = less metadata but coarser dedup.
# CHUNK_MIN=65536
# CHUNK_AVG=262144
# CHUNK_MAX=1048576
